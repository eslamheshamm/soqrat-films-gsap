---
import Layout from "../layouts/Layout.astro";
import medias from "../data.json";
import Header from "../components/header.astro";
---

<Layout uid="home" template="home">
	<div class="slider-page">
		<Header />

		<div class="slider" data-slider>
			<div class="slider__slide slider__slide--video slider__slide--active" data-slide-index="0">
				<video src="https://res.cloudinary.com/dunixnfkj/video/upload/v1776074503/cloth_cfdmfg.mp4" autoplay muted loop playsinline />
			</div>

			{medias.slice(0, 3).map((media, i) => (
				<div
					class="slider__slide"
					style={`background-image: url(${media.url})`}
					data-slide-index={i + 1}
				/>
			))}

			<div class="slider__slide slider__slide--video" data-slide-index="4">
				<video src="https://res.cloudinary.com/dunixnfkj/video/upload/v1776074478/h100_t4l7wf.mp4" autoplay muted loop playsinline />
			</div>

			{medias.slice(3).map((media, i) => (
				<div
					class="slider__slide"
					style={`background-image: url(${media.url})`}
					data-slide-index={i + 5}
				/>
			))}

			<button class="slider__arrow slider__arrow--prev" data-slider-prev aria-label="Previous slide">
				<svg width="24" height="44" viewBox="0 0 24 44" fill="none">
					<path d="M22 2L2 22L22 42" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</button>
			<button class="slider__arrow slider__arrow--next" data-slider-next aria-label="Next slide">
				<svg width="24" height="44" viewBox="0 0 24 44" fill="none">
					<path d="M2 2L22 22L2 42" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</button>

		</div>
	</div>
</Layout>
