	},
];

const films = [
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1775506281/h100_yvvkq0.mp4",
		ar: "1/1",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1775506027/n1666_krrcg1.mp4",
		ar: "1/1",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1774791236/nnn4444.mov",
		ar: "1/1",
	},

	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1775506703/p1_fcelkf.mp4",
		ar: "13/10.8",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1775506687/stills_asea_still_dfedk6.mov",
		ar: "1/1",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1775506682/reel1_no_logo_cpyhq5.mp4",
		ar: "4/5",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1775506626/cloth_f6rqbj.mp4",
		ar: "16/9",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1775506595/final_soq_add_color_xbwdbu.mp4",
		ar: "4/5",
	},

	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1775506415/p2_vwcpsm.mp4",
		ar: "1/1",
	},
];

function getPoster(src: string) {
	return src
		.replace("/video/upload/", "/video/upload/so_0,w_800,e_blur:300,q_40/")
		.replace(/\.\w+$/, ".jpg");
}
---

<Layout uid="films" template="home">
	<div data-gallery-container class="container">
		<Header />

		<section class="films-section">
			<div class="films-horizontal" data-films-horizontal>
				<div class="films-track" data-films-track>
					{
						videos.map((v) => (
							<div class="films-track__item" style={`--ar: ${v.ar};`}>
								<video
									src={v.src}
									poster={getPoster(v.src)}
									autoplay
									muted
									loop
									playsinline
									preload="metadata"
								/>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="films-featured" data-films-stack>
			{
				films.map((v) => (
					<div class="films-panel" data-films-panel>
						<div class="films-panel__inner" style={`--ar: ${v.ar};`}>
							<video
								src={v.src}
								poster={getPoster(v.src)}
								autoplay
								muted
								loop
								playsinline
								preload="metadata"
							/>
						</div>
					</div>
				))
			}
		</section>
	</div>
</Layout>
