		ar: "4/5",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776025680/final_SOQ_glpa5e.mp4",
		ar: "5/4",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776025659/final_2_ro4ac7.mp4",
		ar: "5/4",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776025653/g_osnmfx.mp4",
		ar: "16/9",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776025625/xzxzx_udnhgt.mp4",
		ar: "16/9",
	},

	// {
	// 	src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1775506415/p2_vwcpsm.mp4",
	// 	ar: "1/1",
	// },
];

function getPoster(src: string) {
	return src
		.replace("/video/upload/", "/video/upload/so_0,w_800,e_blur:300,q_40/")
		.replace(/\.\w+$/, ".jpg");
}

function getOptimizedSrc(src: string) {
	return src;
}
---

<Layout uid="films" template="home">
	<div data-gallery-container class="container">
		<Header />

		<section class="films-section">
			<div class="films-marquee" data-films-marquee>
				<div class="films-marquee__track" data-films-marquee-track>
					{
						[...videos, ...videos].map((v) => (
							<div class="films-marquee__item" style={`--ar: ${v.ar};`}>
								<video
									data-src={getOptimizedSrc(v.src)}
									poster={getPoster(v.src)}
									muted
									loop
									playsinline
									preload="none"
								/>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="films-featured" data-films-stack>
			{
				films.map((v) => (
					<div class="films-panel" data-films-panel>
						<div class="films-panel__inner" style={`--ar: ${v.ar};`}>
							<div class="films-player" data-films-player>
								<video
									data-src={v.src}
									poster={getPoster(v.src)}
									playsinline
									preload="none"
								/>
								<button
									class="films-player__btn"
									data-films-play
									aria-label="Play video"
								>
									<svg width="48" height="48" viewBox="0 0 48 48" fill="none">
										<polygon points="18,14 36,24 18,34" fill="currentColor" />
									</svg>
								</button>
							</div>
						</div>
					</div>
				))
			}
		</section>
		<footer class="page-footer">soqrat-films.com</footer>
	</div>
</Layout>
