---
import Layout from "../layouts/Layout.astro";
import Header from "../components/header.astro";

const videos = [
	{ src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1774791182/grid_5x5_tall_2.mov", ar: "4/5" },
	{ src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1774791236/nnn4444.mov", ar: "16/9" },
	{ src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1774791249/grid_2024.mov", ar: "16/9" },
];
---

<Layout uid="films" template="home">
	<div data-gallery-container class="container">
		<Header />
		<div class="films-stack" data-films-stack>
			{videos.map((v, i) => (
				<section class="films-panel" data-films-panel>
					<div class="films-panel__inner" style={`--ar: ${v.ar};`}>
						<video
							src={v.src}
							autoplay
							muted
							loop
							playsinline
						/>
					</div>
				</section>
			))}
		</div>
	</div>
</Layout>

<style>
	.films-panel {
		width: 100%;
		height: 100dvh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: var(--page-padding);
	}

	.films-panel__inner {
		width: 100%;
		max-width: 80vw;
		max-height: 85vh;
		aspect-ratio: var(--ar);
		overflow: hidden;
		filter: grayscale(1);
	}

	.films-panel__inner video {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
</style>

<script>
	import gsap from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { Observer } from "gsap/Observer";
	import { ScrollToPlugin } from "gsap/ScrollToPlugin";

	gsap.registerPlugin(ScrollTrigger, Observer, ScrollToPlugin);

	function initFilmsScroll() {
		const panels = gsap.utils.toArray<HTMLElement>("[data-films-panel]");
		if (!panels.length) return;

		const sections = panels;
		let currentIndex = 0;
		let isAnimating = false;
		let cooldown = false;

		function goToSection(index: number) {
			if (index < 0 || index >= sections.length || isAnimating || cooldown) return;
			isAnimating = true;
			cooldown = true;
			currentIndex = index;

			// Use offsetTop for stable position unaffected by ScrollSmoother transforms
			const el = sections[index];
			const elTop = el.offsetTop;
			const elHeight = el.offsetHeight;
			const viewportHeight = window.innerHeight;
			const targetScroll = elTop - (viewportHeight - elHeight) / 2;

			gsap.to(window, {
				scrollTo: { y: Math.max(0, targetScroll), autoKill: false },
				duration: 0.8,
				ease: "power3.inOut",
				onComplete: () => {
					isAnimating = false;
					gsap.delayedCall(0.4, () => { cooldown = false; });
				},
			});
		}

		Observer.create({
			type: "wheel,touch,pointer",
			wheelSpeed: -1,
			tolerance: 50,
			onUp: () => goToSection(currentIndex + 1),
			onDown: () => goToSection(currentIndex - 1),
			preventDefault: true,
		});
	}

	document.addEventListener("DOMContentLoaded", initFilmsScroll);

	window.addEventListener("barba:after", () => {
		requestAnimationFrame(initFilmsScroll);
	});
</script>
