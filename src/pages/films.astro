	},
];

const films = [
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1775506027/n1666_krrcg1.mp4",
		ar: "1/1",
	},

	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1775506703/p1_fcelkf.mp4",
		ar: "13/10.8",
	},

	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1775506682/reel1_no_logo_cpyhq5.mp4",
		ar: "4/5",
	},
	// {
	// 	src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1775506626/cloth_f6rqbj.mp4",
	// 	ar: "16/9",
	// },
	{
