---
import Layout from "../layouts/Layout.astro";
import Header from "../components/header.astro";

const videos = [
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074601/1_uisfnc.mov",
		ar: "4/5",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074653/2_bdjlxj.mov",
		ar: "4/5",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074649/3_xwazw0.mov",
		ar: "4/5",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074630/4_urk9a0.mov",
		ar: "4/5",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074628/5_bdvea8.mov",
		ar: "4/5",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074672/6_zn7c8k.mov",
		ar: "13/11.55",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074632/7_ih2rbi.mov",
		ar: "4/5",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074656/8_m5lgwq.mov",
		ar: "4/5",
	},
];

const films = [
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074504/n1666_nwqgvp.mp4",
		ar: "1/1",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074590/p1_anjil2.mp4",
		ar: "13/10.8",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074611/reel1_no_logo_ilsp0e.mp4",
		ar: "4/5",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074540/final_soq_add_color_imhhim.mp4",
		ar: "4/5",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074653/final_SOQ_dqlkqr.mp4",
		ar: "5/4",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074619/final_2_ggplmf.mp4",
		ar: "5/4",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074612/g_cyamul.mp4",
		ar: "16/9",
	},
	{
		src: "https://res.cloudinary.com/dunixnfkj/video/upload/v1776074661/xzxzx_vl9bc2.mp4",
		ar: "16/9",
	},
];

function getPoster(src: string) {
	return src
		.replace("/video/upload/", "/video/upload/so_0,w_800,e_blur:300,q_40/")
		.replace(/\.\w+$/, ".jpg");
}

function getOptimizedSrc(src: string) {
	return src;
}
---

<Layout uid="films" template="home">
	<div data-gallery-container class="container">
		<Header />

		<section class="films-section">
			<div class="films-marquee" data-films-marquee>
				<div class="films-marquee__track" data-films-marquee-track>
					{
						[...videos, ...videos].map((v) => (
							<div class="films-marquee__item" style={`--ar: ${v.ar};`}>
								<video
									data-src={getOptimizedSrc(v.src)}
									poster={getPoster(v.src)}
									muted
									loop
									playsinline
									preload="none"
								/>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="films-featured" data-films-stack>
			{
				films.map((v) => (
					<div class="films-panel" data-films-panel>
						<div class="films-panel__inner" style={`--ar: ${v.ar};`}>
							<div class="films-player" data-films-player>
								<video
									data-src={v.src}
									poster={getPoster(v.src)}
									playsinline
									preload="none"
								/>
								<button
									class="films-player__btn"
									data-films-play
									aria-label="Play video"
								>
									<svg width="48" height="48" viewBox="0 0 48 48" fill="none">
										<polygon points="18,14 36,24 18,34" fill="currentColor" />
									</svg>
								</button>
							</div>
						</div>
					</div>
				))
			}
		</section>
		<footer class="page-footer">
			<a href="/" class="page-footer__logo">
				<span class="logo__img" role="img" aria-label="Soqrat Films"></span>
			</a>
		</footer>
	</div>
</Layout>
