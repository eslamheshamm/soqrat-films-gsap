---
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="frame">
	<a href="/" class="logo">
		<span class="logo__img" role="img" aria-label="Soqrat Films"></span>
	</a>
	<ul class="frame__nav">
		<li><a href="/about" class={pathname === '/about' ? 'is-active' : ''}>About</a></li>
		<li><a href="/films" class={pathname === '/films' ? 'is-active' : ''}>Films</a></li>
		<li><a href="/contact" class={pathname === '/contact' ? 'is-active' : ''}>Contact</a></li>
	</ul>
	<button class="hamburger" data-hamburger aria-label="Open menu">
		<span class="hamburger__line"></span>
		<span class="hamburger__line"></span>
	</button>
</header>
